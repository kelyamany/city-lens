{
  "name": "urban-lens",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "preprocess": "bun scripts/preprocess.ts",
    "build": "bun scripts/preprocess.ts && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",

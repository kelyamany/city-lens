    "@types/mapbox-gl": "^3.5.0",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/svelte": "^4.0.141",
    "@sveltejs/adapter-node": "^5.5.4",
    "ai": "^6.0.141",
    "lucide-svelte": "^1.0.1",
    "mapbox-gl": "^3.20.0",
    "marked": "^17.0.5",
    "zod": "^4.3.6"
